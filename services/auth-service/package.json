{
  "name": "@lms/auth-service",
  "version": "0.1.0",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "type": "commonjs",
  "scripts": {
    "dev": "ts-node-dev --respawn --transpile-only src/index.ts",
    "build": "prisma generate --schema=prisma/schema.prisma && tsc -p tsconfig.json",
    "start": "node dist/index.js",
    "test": "jest",
    "test:unit": "jest --testMatch '**/*.unit.test.ts'",
    "test:integration": "jest --testMatch '**/*.integration.test.ts'",
    "migrate": "prisma migrate dev",
    "seed": "prisma db seed"
  },
  "prisma": {
    "seed": "ts-node-dev --transpile-only prisma/seed.ts"
  },
  "dependencies": {
    "@lms/shared": "0.1.0",
    "@prisma/client": "^5.13.0",
    "bcryptjs": "^2.4.3",
    "dotenv": "^16.4.5",
    "express": "^4.19.2",
    "jsonwebtoken": "^9.0.2",
    "zod": "^3.23.6"
  },
  "devDependencies": {
    "@types/bcryptjs": "^2.4.6",
    "@types/express": "^4.17.21",
    "@types/jest": "^29.5.12",
    "@types/jsonwebtoken": "^9.0.6",
    "@types/node": "^20.11.30",
    "@types/supertest": "^2.0.16",
    "prisma": "^5.13.0",
    "supertest": "^6.3.4",
    "ts-jest": "^29.1.2",
    "ts-node-dev": "^2.0.0",
    "typescript": "^5.4.5"
  }
}
