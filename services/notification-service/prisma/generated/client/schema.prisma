generator client {
  provider = "prisma-client-js"
  output   = "./generated/client"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum CampaignStatus {
  DRAFT
  SENT
  FAILED
}

model Campaign {
  id        String         @id @default(uuid())
  subject   String
  body      String
  status    CampaignStatus @default(DRAFT)
  createdAt DateTime       @default(now())
  sentAt    DateTime?
}

model EmailLog {
  id         String   @id @default(uuid())
  campaignId String
  recipient  String
  status     String
  error      String?
  createdAt  DateTime @default(now())
}

model HealthPing {
  id        String   @id @default(uuid())
  createdAt DateTime @default(now())
}
