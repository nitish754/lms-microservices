generator client {
  provider = "prisma-client-js"
  output   = "./generated/client"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum CourseStatus {
  DRAFT
  PUBLISHED
  ARCHIVED
}

enum CourseCategory {
  TECH
  DESIGN
  SOFTWARE
  BUSINESS
  OTHER
}

model Course {
  id          String        @id @default(uuid())
  teacherId   String
  title       String
  description String
  authorName  String
  tags        String[]
  category    CourseCategory
  status      CourseStatus  @default(DRAFT)
  createdAt   DateTime      @default(now())
  updatedAt   DateTime      @updatedAt
}

model HealthPing {
  id        String   @id @default(uuid())
  createdAt DateTime @default(now())
}
